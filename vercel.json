{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build && cd api && npm ci --prefer-offline=false",
  "outputDirectory": "frontend",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/$1"
    }
  ],
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/[...path].js": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}