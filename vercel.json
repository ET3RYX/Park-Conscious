{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": ".",
  "buildCommand": "npm run build && cd api && npm ci --prefer-offline=false",
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend/$1"
    }
  ],
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/[...path].js": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}